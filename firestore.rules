rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBSDate(date) {
      return date is string && date.size() == 10 && date.matches('^\\d{4}/\\d{2}/\\d{2}$');
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['firmName', 'email', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.firmName is string && data.firmName.size() <= 200 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().email == existing().email && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['firmName']);

      // --- Cheque Records ---
      match /cheques/{chequeId} {
        function isValidCheque(data) {
          return data.keys().hasAll(['userId', 'bankName', 'customerName', 'amount', 'chequeDateBS', 'receivedDateBS', 'contactNo', 'status', 'createdAt', 'updatedAt', 'remarks']) &&
                 data.keys().size() == 11 &&
                 data.userId == userId &&
                 data.bankName is string && data.bankName.size() <= 200 &&
                 data.customerName is string && data.customerName.size() <= 200 &&
                 data.amount is number && data.amount >= 0 &&
                 isValidBSDate(data.chequeDateBS) &&
                 isValidBSDate(data.receivedDateBS) &&
                 data.contactNo is string && data.contactNo.size() <= 20 &&
                 data.status in ['BOUNCE', 'CLEAR', 'POSTDATED'] &&
                 data.remarks is string && data.remarks.size() <= 1000 &&
                 data.createdAt is timestamp &&
                 data.updatedAt is timestamp;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chequeId) && isValidCheque(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidCheque(incoming()) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;
        allow delete: if isOwner(userId);
      }

      // --- Bank Details ---
      match /banks/{bankId} {
        function isValidBank(data) {
          return data.keys().hasAll(['userId', 'bankName', 'createdAt']) &&
                 (data.keys().size() >= 3 && data.keys().size() <= 5) &&
                 data.userId == userId &&
                 data.bankName is string && data.bankName.size() <= 200 &&
                 data.createdAt is timestamp;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(bankId) && isValidBank(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidBank(incoming()) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(userId);
      }

      // --- Customer Details ---
      match /customers/{customerId} {
        function isValidCustomer(data) {
          return data.keys().hasAll(['userId', 'customerName', 'createdAt']) &&
                 (data.keys().size() >= 3 && data.keys().size() <= 4) &&
                 data.userId == userId &&
                 data.customerName is string && data.customerName.size() <= 200 &&
                 data.createdAt is timestamp;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(customerId) && isValidCustomer(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidCustomer(incoming()) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}
